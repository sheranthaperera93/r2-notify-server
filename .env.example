# Server
PORT=8080
ENV=development
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# MongoDB (Atlas)
MONGO_SCHEMA=mongodb+srv
MONGO_HOST=your-cluster.mongodb.net
MONGO_PORT=27017
MONGO_DB_NAME=r2notify
MONGO_USERNAME=your_mongo_user
MONGO_PASSWORD=your_mongo_password
MONGO_RETRY_WRITES=true
MONGO_SSL=false

# Redis (Render)
REDIS_HOST=your-redis-host.render.com
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=your_redis_password
REDIS_TLS_ENABLED=false

# JWT (user dashboard sessions)
JWT_SECRET=your_jwt_secret_min_32_chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# Azure Event Hub (set ENABLE_EVENT_HUB=true to activate the consumer)
ENABLE_EVENT_HUB=false
EVENT_HUB_NAMESPACE_CON_STRING=Endpoint=sb://your-namespace.servicebus.windows.net/;SharedAccessKeyName=...
EVENT_HUB_NOTIFICATION_EVENT_NAME=notifications

# Unkey (API key management + validation)
UNKEY_ROOT_KEY=your_unkey_root_key
UNKEY_API_ID=your_unkey_api_id

# Email (Resend)
RESEND_API_KEY=your_resend_api_key
RESEND_FROM=noreply@r2notify.dev

# App
APP_BASE_URL=http://localhost:5173
ALLOWED_API_KEY_COUNT=5

# Logging
LOG_LEVEL=info
LOG_METHOD=file
LOG_FILE_PATH=./logs/app.log
MAX_LOG_FILE_SIZE=10
APP_INSIGHTS_INSTRUMENTATION_KEY=
